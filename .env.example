# キュアサークル環境変数設定例

# Supabase設定
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# NextAuth設定
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Spotify API (オプション)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/auth

# メンテナンスモード設定
# true に設定するとメンテナンスモードが有効になります
NEXT_PUBLIC_MAINTENANCE_MODE=false

# メンテナンス時のパスワード
# このパスワードを知っているユーザーのみメンテナンス中でもアクセス可能
NEXT_PUBLIC_MAINTENANCE_PASSWORD=precure_rainbow

# 管理者用パスワード
# メンテナンスモード設定変更に必要なパスワード
ADMIN_MAINTENANCE_PASSWORD=admin_precure
